        "sendQuery": true,
        "specifyQuery": "json",
        "jsonQuery": "{\n  \"part\": \"statistics,contentDetails\",\n  \"id\": \"={{$json.ids}}\",\n  \"key\": \"AIzaSyBSuxz-rXOxOO_aaOcooo3PA8QxdS-H6CY\"\n}",
        "options": {}
      },
      "name": "Get Stats + Duration",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1300, 300],
      "id": "stats-duration"
    },
    {
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "id": "vues-min",
              "leftValue": "={{ Number($json.statistics.viewCount) }}",
              "rightValue": 5000,
              "operator": { "type": "number", "operation": "largerEqual" }
            },
            {
              "id": "likes-min", 
              "leftValue": "={{ Number($json.statistics.likeCount) }}",
              "rightValue": 200,
              "operator": { "type": "number", "operation": "largerEqual" }
            },
            {
              "id": "duration-ok",
              "leftValue": "={{ $json.contentDetails.duration }}",
              "rightValue": "PT5M",
              "operator": { "type": "string", "operation": "regex", "value2": "^PT(?:[1-9][0-9]*H)?[5-9][0-9]*M|PT[1-9][0-9]*H" }
            },
            {
              "id": "no-shorts",
              "leftValue": "={{ $json.contentDetails.duration }}",
              "rightValue": "PT1M",
              "operator": { "type": "string", "operation": "smaller" }
            },
            {
              "id": "title-quality",
              "leftValue": "={{ $json.snippet.title.length }}",
              "rightValue": 120,
              "operator": { "type": "number", "operation": "smallerEqual" }
            }
          ],
          "combinator": "and"
        }
      },
      "name": "Filter Qualité Stricte",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 2,
      "position": [1520, 300],
      "id": "quality-filter"
    },
    {
      "parameters": {
        "functionCode": "// Merge search + stats + scoring\nconst searchItems = $('Search Videos Fiable').first().json.items;\nconst statsItems = items[0].json.items || [];\nconst statsMap = {};\n\nstatsItems.forEach(stat => {\n  statsMap[stat.id] = stat;\n});\n\nfunction isoToMinutes(iso) {\n  const match = iso.match(/PT(?:(\\d+)H)?(?:(\\d+)M)?(?:(\\d+)S)?/);\n  return (parseInt(match?.[1] || 0) * 60) + parseInt(match?.[2] || 0);\n}\n\nconst keyword = $('Webhook1').first().json.query.keyword.toLowerCase();\nconst keywordWords = keyword.split(' ').filter(w => w.length > 2);\n\n// Score pertinence + qualité\nreturn searchItems\n  .map(video => {\n    const stats = statsMap[video.id.videoId];\n    if (!stats) return null;\n    \n    const title = video.snippet.title.toLowerCase();\n    const relevance = keywordWords.filter(word => title.includes(word)).length / keywordWords.length;\n    const qualityScore = (Number(stats.statistics?.viewCount || 0) / 10000) * 0.4 + \n                        (Number(stats.statistics?.likeCount || 0) / 1000) * 0.3 +\n                        (isoToMinutes(stats.contentDetails.duration) / 60) * 0.3;\n                        \n    return {\n      json: {\n        title: video.snippet.title,\n        channel: video.snippet.channelTitle,\n        views: Number(stats.statistics?.viewCount || 0),\n        likes: Number(stats.statistics?.likeCount || 0),\n        duration: isoToMinutes(stats.contentDetails.duration),\n        durationFormatted: `${Math.floor(isoToMinutes(stats.contentDetails.duration)/60)}:${(isoToMinutes(stats.contentDetails.duration)%60).toString().padStart(2,'0')}`,\n        url: `https://youtube.com/watch?v=${video.id.videoId}`,\n        publishedAt: video.snippet.publishedAt,\n        score: (relevance * 0.6 + qualityScore * 0.4).toFixed(2),\n        keyword\n      }\n    };\n  })\n  .filter(Boolean)\n  .sort((a, b) => parseFloat(b.json.score) - parseFloat(a.json.score))\n  .slice(0, 5);"
      },
      "name": "Score & Top 5",
      "type": "n8n-nodes-base.function",
      "position": [1740, 300],
      "id": "scoring"
    },
