    },
    {
      "parameters": {
        "functionCode": "const videoIds = items[0].json.items.map(v => v.id.videoId).join(',');\nreturn [{ json: { ids: videoIds, raw: items[0].json.items } }];"
      },
      "name": "Extract IDs",
      "type": "n8n-nodes-base.function",
      "position": [1100, 300],
      "id": "50e1c9ac-f872-43e5-ae73-bebac0e163dd"
    },
    {
