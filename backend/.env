# =============================================================
# SAMAKMARKET - Variables d'environnement
# =============================================================
# IMPORTANT : Copie ce fichier et renomme-le ".env"
#             Le fichier .env ne doit JAMAIS être partagé
#             ou mis sur GitHub (contient des infos secrètes)
# =============================================================

# --- SERVEUR ---
PORT=3000
NODE_ENV=development        # "development" ou "production"

# --- BASE DE DONNÉES MYSQL ---
DB_HOST=localhost           # Adresse du serveur MySQL (localhost = sur ta machine)
DB_PORT=3306                # Port MySQL par défaut
DB_NAME=samakmarket         # Nom de la base de données créée avec database.sql
DB_USER=root                # Ton utilisateur MySQL
DB_PASSWORD=Solution@101984-

# --- JWT (Authentification) ---
# Clé secrète utilisée pour signer les tokens de connexion
# Change cette valeur par quelque chose de long et aléatoire !
JWT_SECRET=samakmarket_super_cle_secrete_change_moi_en_prod_2024
JWT_EXPIRES_IN=7d           # Durée de validité du token (7 jours)

# --- FRONTEND ---
# URL du frontend Vue.js (pour autoriser les requêtes cross-origin)
FRONTEND_URL=http://localhost:5173
